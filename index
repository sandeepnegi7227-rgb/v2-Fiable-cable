<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Fiable Cables — Narela, Delhi | Copper Wire Manufacturers</title>
  <link href="https://fonts.googleapis.com/css2?family=Barlow:ital,wght@0,300;0,400;0,500;0,600;0,700;1,700&family=Barlow+Condensed:wght@600;700;800&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --red:        #E02020;
      --red-dark:   #B81818;
      --red-glow:   #FF3333;
      --charcoal:   #1A1A1A;
      --ink:        #0D0D0D;
      --ink-panel:  #141414;
      --ink-raised: #1E1E1E;
      --rule:       #2A2A2A;
      --rule-light: #333333;
      --off-white:  #F2F2F2;
      --muted:      #777777;
      --white:      #FFFFFF;
    }

    html { scroll-behavior: smooth; }
    body {
      font-family: 'Barlow', sans-serif;
      background: var(--ink);
      color: var(--off-white);
      overflow-x: hidden;
    }

    /* ── LOADER ── */
    #loader {
      position: fixed; inset: 0; z-index: 999;
      background: var(--ink);
      display: flex; flex-direction: column;
      align-items: center; justify-content: center; gap: 2rem;
      transition: opacity 0.7s ease, visibility 0.7s ease;
    }
    #loader.hidden { opacity: 0; visibility: hidden; }
    #loader img { width: 220px; filter: brightness(0) invert(1); }
    .loader-bar-track { width: 220px; height: 2px; background: var(--rule); }
    .loader-bar-fill {
      height: 2px; width: 0;
      background: var(--red);
      animation: loadfill 1.5s cubic-bezier(0.4,0,0.2,1) forwards;
    }
    @keyframes loadfill { to { width: 100%; } }
    .loader-label {
      font-family: 'DM Mono', monospace;
      font-size: 0.6rem; color: var(--muted);
      letter-spacing: 0.22em; text-transform: uppercase;
    }

    /* ── NAV ── */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 4%; height: 70px;
      background: rgba(13,13,13,0.97);
      backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--rule);
    }
    .nav-logo img {
      height: 38px;
      filter: brightness(0) invert(1);
      display: block;
    }
    .nav-links { display: flex; gap: 2.5rem; list-style: none; }
    .nav-links a {
      font-size: 0.72rem; font-weight: 600;
      letter-spacing: 0.14em; text-transform: uppercase;
      color: var(--muted); text-decoration: none; transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--off-white); }
    .nav-right { display: flex; align-items: center; gap: 1.5rem; }
    .nav-location {
      font-family: 'DM Mono', monospace;
      font-size: 0.6rem; color: var(--muted);
      letter-spacing: 0.1em; text-transform: uppercase;
    }
    .nav-cta {
      background: var(--red); color: var(--white);
      border: none; padding: 0.55rem 1.5rem;
      font-family: 'Barlow', sans-serif;
      font-size: 0.72rem; font-weight: 600;
      letter-spacing: 0.12em; text-transform: uppercase;
      cursor: pointer; transition: background 0.2s;
    }
    .nav-cta:hover { background: var(--red-dark); }

    /* ── HERO ── */
    .hero {
      min-height: 100vh;
      display: grid; grid-template-columns: 1fr 1fr;
      align-items: center;
      padding: 120px 4% 80px; gap: 4rem;
      position: relative; overflow: hidden;
    }
    .hero-bg {
      position: absolute; inset: 0; pointer-events: none;
      overflow: hidden; z-index: 0;
    }
    .hero-bg svg { width: 100%; height: 100%; }
    .hero-left { position: relative; z-index: 1; }
    .hero-right { position: relative; z-index: 1; }

    .hero-kicker {
      display: flex; align-items: center; gap: 1rem; margin-bottom: 2rem;
    }
    .kicker-line { width: 36px; height: 2px; background: var(--red); }
    .kicker-text {
      font-family: 'DM Mono', monospace;
      font-size: 0.6rem; color: var(--red);
      letter-spacing: 0.22em; text-transform: uppercase;
    }

    .hero-logo-large {
      width: 280px; margin-bottom: 2.5rem;
      filter: brightness(0) invert(1);
    }

    .hero-headline {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: clamp(2.8rem, 5vw, 5rem);
      font-weight: 800; line-height: 1.0;
      color: var(--white); text-transform: uppercase;
      letter-spacing: 0.02em; margin-bottom: 1.6rem;
    }
    .hero-headline span { color: var(--red); }

    .hero-sub {
      font-size: 1rem; font-weight: 300; line-height: 1.85;
      color: var(--muted); max-width: 460px; margin-bottom: 2.8rem;
    }
    .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }
    .btn-red {
      background: var(--red); color: var(--white);
      border: none; padding: 0.9rem 2.2rem;
      font-family: 'Barlow', sans-serif;
      font-size: 0.75rem; font-weight: 600;
      letter-spacing: 0.14em; text-transform: uppercase;
      cursor: pointer; text-decoration: none; display: inline-block;
      transition: background 0.2s;
    }
    .btn-red:hover { background: var(--red-dark); }
    .btn-ghost {
      background: transparent; color: var(--off-white);
      border: 1px solid var(--rule-light);
      padding: 0.9rem 2.2rem;
      font-family: 'Barlow', sans-serif;
      font-size: 0.75rem; font-weight: 600;
      letter-spacing: 0.14em; text-transform: uppercase;
      cursor: pointer; text-decoration: none; display: inline-block;
      transition: border-color 0.2s, color 0.2s;
    }
    .btn-ghost:hover { border-color: var(--red); color: var(--white); }

    .hero-stats { display: flex; flex-direction: column; gap: 1.5px; }
    .hsc {
      background: var(--ink-panel);
      border-left: 3px solid var(--red);
      padding: 1.5rem 2rem;
    }
    .hsc-val {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 2.6rem; font-weight: 800;
      color: var(--white); line-height: 1;
    }
    .hsc-val span { color: var(--red); }
    .hsc-label {
      font-family: 'DM Mono', monospace;
      font-size: 0.58rem; color: var(--muted);
      letter-spacing: 0.14em; text-transform: uppercase; margin-top: 0.3rem;
    }
    .hsc-sub { font-size: 0.75rem; color: var(--muted); margin-top: 0.2rem; }

    /* ── RED RULE ── */
    .red-rule {
      height: 2px;
      background: linear-gradient(90deg, transparent 0%, var(--red) 30%, var(--red-glow) 60%, transparent 100%);
    }

    /* ── SECTION BASE ── */
    .section { padding: 100px 4%; }
    .section-label {
      display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem;
    }
    .sl-line { width: 32px; height: 2px; background: var(--red); }
    .sl-text {
      font-family: 'DM Mono', monospace;
      font-size: 0.6rem; color: var(--red);
      letter-spacing: 0.22em; text-transform: uppercase;
    }
    .section-title {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: clamp(2.2rem, 4vw, 3.6rem);
      font-weight: 800; text-transform: uppercase;
      line-height: 1.0; color: var(--white); margin-bottom: 1.4rem;
      letter-spacing: 0.02em;
    }
    .section-title span { color: var(--red); }
    .section-body {
      font-size: 0.92rem; line-height: 1.9;
      color: var(--muted); max-width: 520px;
    }

    /* ── ABOUT ── */
    .about { background: var(--charcoal); }
    .about-inner {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 6rem; align-items: center;
    }
    .about-right { display: flex; flex-direction: column; gap: 2rem; }
    .about-pull {
      font-size: 1.2rem; font-weight: 500; font-style: italic;
      color: var(--off-white); line-height: 1.6;
      border-left: 3px solid var(--red); padding-left: 1.5rem;
    }
    .about-body { font-size: 0.88rem; line-height: 1.95; color: var(--muted); }
    .about-tags { display: flex; gap: 0.7rem; flex-wrap: wrap; }
    .tag {
      font-family: 'DM Mono', monospace;
      font-size: 0.58rem; letter-spacing: 0.12em; text-transform: uppercase;
      color: var(--red); border: 1px solid var(--red);
      padding: 0.28rem 0.75rem;
    }

    /* ── PROCESS ── */
    .process { background: var(--ink); }
    .process-timeline {
      margin-top: 4rem;
      display: grid; grid-template-columns: repeat(5, 1fr);
      gap: 0; position: relative;
    }
    .process-track {
      position: absolute; top: 27px; left: 5%; right: 5%; height: 2px;
      background: linear-gradient(90deg, var(--red), var(--red-glow), var(--red));
      z-index: 0;
    }
    .process-step {
      display: flex; flex-direction: column; align-items: center;
      text-align: center; padding: 0 0.8rem; position: relative; z-index: 1;
    }
    .ps-node {
      width: 56px; height: 56px; border-radius: 50%;
      background: var(--ink-panel); border: 2px solid var(--red);
      display: flex; align-items: center; justify-content: center;
      margin-bottom: 1.5rem;
    }
    .ps-node svg { width: 22px; height: 22px; }
    .ps-title {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.95rem; font-weight: 700; text-transform: uppercase;
      color: var(--white); margin-bottom: 0.6rem; letter-spacing: 0.04em;
    }
    .ps-body { font-size: 0.74rem; line-height: 1.7; color: var(--muted); }

    /* ── CATALOGUE ── */
    .catalogue { background: var(--charcoal); }
    .cat-header {
      display: flex; align-items: flex-end;
      justify-content: space-between; margin-bottom: 3rem;
      flex-wrap: wrap; gap: 2rem;
    }
    .cat-filters { display: flex; gap: 0.5rem; flex-wrap: wrap; }
    .cat-filter {
      font-family: 'DM Mono', monospace;
      font-size: 0.6rem; letter-spacing: 0.1em; text-transform: uppercase;
      color: var(--muted); border: 1px solid var(--rule);
      background: transparent; padding: 0.42rem 1rem;
      cursor: pointer; transition: all 0.2s;
    }
    .cat-filter.active, .cat-filter:hover {
      color: var(--white); background: var(--red); border-color: var(--red);
    }
    .cat-grid {
      display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5px;
    }
    .cat-card {
      background: var(--ink-panel);
      padding: 2.5rem 2rem;
      border-bottom: 3px solid transparent;
      transition: border-color 0.25s, background 0.2s;
      position: relative; overflow: hidden;
    }
    .cat-card::after {
      content: '';
      position: absolute; bottom: 0; left: 0; right: 0; height: 3px;
      background: var(--red);
      transform: scaleX(0); transform-origin: left;
      transition: transform 0.3s ease;
    }
    .cat-card:hover::after { transform: scaleX(1); }
    .cat-card:hover { background: var(--ink-raised); }

    .cat-cat {
      font-family: 'DM Mono', monospace;
      font-size: 0.56rem; color: var(--red);
      letter-spacing: 0.2em; text-transform: uppercase; margin-bottom: 1rem;
    }
    .cat-name {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 1.3rem; font-weight: 700; text-transform: uppercase;
      color: var(--white); margin-bottom: 0.7rem; line-height: 1.2;
      letter-spacing: 0.03em;
    }
    .cat-desc { font-size: 0.8rem; line-height: 1.75; color: var(--muted); margin-bottom: 1.6rem; }
    .cat-specs {
      display: flex; flex-direction: column; gap: 0.55rem;
      border-top: 1px solid var(--rule); padding-top: 1.3rem; margin-bottom: 1.6rem;
    }
    .cat-spec-row { display: flex; justify-content: space-between; align-items: center; }
    .cat-spec-k {
      font-family: 'DM Mono', monospace;
      font-size: 0.58rem; color: var(--muted); letter-spacing: 0.08em; text-transform: uppercase;
    }
    .cat-spec-v { font-size: 0.74rem; color: var(--off-white); font-weight: 500; }
    .cat-footer { display: flex; justify-content: space-between; align-items: center; }
    .cat-std {
      font-family: 'DM Mono', monospace;
      font-size: 0.56rem; color: var(--rule-light); letter-spacing: 0.08em; text-transform: uppercase;
    }
    .cat-enquire {
      font-size: 0.68rem; font-weight: 600;
      letter-spacing: 0.1em; text-transform: uppercase;
      color: var(--red); background: transparent;
      border: none; cursor: pointer; text-decoration: none;
      display: flex; align-items: center; gap: 0.4rem; transition: gap 0.2s;
    }
    .cat-enquire:hover { gap: 0.7rem; }

    .cat-download-banner {
      margin-top: 1.5px; background: var(--ink-raised);
      border: 1px solid var(--rule);
      padding: 2.5rem 3rem;
      display: flex; align-items: center; justify-content: space-between;
      flex-wrap: wrap; gap: 2rem;
    }
    .cdb-left h3 {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 1.4rem; font-weight: 700; text-transform: uppercase;
      color: var(--white); margin-bottom: 0.3rem; letter-spacing: 0.04em;
    }
    .cdb-left p { font-size: 0.8rem; color: var(--muted); }
    .cdb-right { display: flex; gap: 1rem; flex-wrap: wrap; }
    .cdb-dl {
      display: flex; align-items: center; gap: 0.8rem;
      border: 1px solid var(--rule-light);
      padding: 0.8rem 1.4rem; text-decoration: none; transition: border-color 0.2s;
    }
    .cdb-dl:hover { border-color: var(--red); }
    .cdb-dl-icon {
      width: 32px; height: 32px; background: var(--ink-panel);
      display: flex; align-items: center; justify-content: center;
    }
    .cdb-dl-name { font-size: 0.75rem; font-weight: 500; color: var(--off-white); display: block; }
    .cdb-dl-format {
      font-family: 'DM Mono', monospace;
      font-size: 0.56rem; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; display: block;
    }

    /* ── CERTS ── */
    .certs { background: var(--ink); }
    .certs-inner { display: grid; grid-template-columns: 1fr 2fr; gap: 5rem; align-items: center; }
    .cert-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5px; }
    .cert-tile {
      background: var(--ink-panel); padding: 1.5rem 1rem;
      display: flex; flex-direction: column; align-items: center; gap: 0.6rem;
      text-align: center; border-top: 2px solid transparent; transition: border-color 0.2s;
    }
    .cert-tile:hover { border-color: var(--red); }
    .cert-icon {
      width: 36px; height: 36px; background: var(--red);
      display: flex; align-items: center; justify-content: center;
      font-family: 'DM Mono', monospace;
      font-size: 0.52rem; font-weight: 500; color: var(--white); letter-spacing: 0.04em;
    }
    .cert-tile-name {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.8rem; font-weight: 700; text-transform: uppercase;
      color: var(--white); letter-spacing: 0.06em;
    }
    .cert-tile-body { font-size: 0.68rem; color: var(--muted); line-height: 1.5; }

    /* ── WHY ── */
    .why { background: var(--charcoal); }
    .why-grid {
      margin-top: 3.5rem;
      display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5px;
    }
    .why-card {
      background: var(--ink-panel); padding: 2.5rem 1.8rem; position: relative;
    }
    .why-card::before {
      content: attr(data-num);
      position: absolute; top: 1.2rem; right: 1.2rem;
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 4rem; font-weight: 800;
      color: var(--rule); line-height: 1;
    }
    .why-accent { width: 28px; height: 3px; background: var(--red); margin-bottom: 1rem; }
    .why-card h4 {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 1.1rem; font-weight: 700; text-transform: uppercase;
      color: var(--white); margin-bottom: 0.8rem; letter-spacing: 0.04em;
    }
    .why-card p { font-size: 0.78rem; line-height: 1.8; color: var(--muted); }

    /* ── CONTACT ── */
    .contact { background: var(--ink); }
    .contact-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 7rem; }
    .contact-map {
      background: var(--ink-panel); border: 1px solid var(--rule);
      border-left: 3px solid var(--red); padding: 2rem; margin-bottom: 2rem;
    }
    .map-label {
      font-family: 'DM Mono', monospace;
      font-size: 0.58rem; color: var(--red);
      letter-spacing: 0.2em; text-transform: uppercase; margin-bottom: 0.8rem;
    }
    .map-address { font-size: 0.88rem; line-height: 1.7; color: var(--off-white); }
    .map-pin {
      display: flex; align-items: center; gap: 0.5rem; margin-top: 1rem;
      font-family: 'DM Mono', monospace;
      font-size: 0.58rem; color: var(--muted); letter-spacing: 0.08em; text-transform: uppercase;
    }
    .map-pin-dot {
      width: 8px; height: 8px; border-radius: 50%;
      background: var(--red); box-shadow: 0 0 8px var(--red);
    }
    .contact-channels { display: flex; flex-direction: column; gap: 1.2rem; }
    .channel {
      display: flex; gap: 1.2rem; align-items: flex-start;
      padding-bottom: 1.2rem; border-bottom: 1px solid var(--rule);
    }
    .channel:last-child { border-bottom: none; }
    .channel-icon {
      width: 36px; height: 36px; flex-shrink: 0;
      background: var(--red);
      display: flex; align-items: center; justify-content: center;
    }
    .channel-label {
      font-family: 'DM Mono', monospace;
      font-size: 0.56rem; color: var(--red);
      letter-spacing: 0.14em; text-transform: uppercase; margin-bottom: 0.3rem;
    }
    .channel-val { font-size: 0.85rem; color: var(--off-white); }

    .contact-form { display: flex; flex-direction: column; gap: 1.2rem; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .form-field { display: flex; flex-direction: column; gap: 0.45rem; }
    .form-field label {
      font-family: 'DM Mono', monospace;
      font-size: 0.58rem; color: var(--muted);
      letter-spacing: 0.12em; text-transform: uppercase;
    }
    .form-field input,
    .form-field select,
    .form-field textarea {
      background: var(--ink-panel); border: 1px solid var(--rule);
      border-bottom: 2px solid var(--rule);
      color: var(--off-white); padding: 0.8rem 1rem;
      font-family: 'Barlow', sans-serif; font-size: 0.85rem;
      outline: none; transition: border-bottom-color 0.2s;
    }
    .form-field input:focus,
    .form-field select:focus,
    .form-field textarea:focus { border-bottom-color: var(--red); }
    .form-field textarea { resize: vertical; min-height: 110px; }
    .form-field select option { background: var(--ink-panel); }
    .form-submit {
      background: var(--red); color: var(--white); border: none;
      padding: 1rem 2.4rem;
      font-family: 'Barlow', sans-serif;
      font-size: 0.75rem; font-weight: 600;
      letter-spacing: 0.14em; text-transform: uppercase;
      cursor: pointer; transition: background 0.2s; align-self: flex-start;
    }
    .form-submit:hover { background: var(--red-dark); }

    /* ── FOOTER ── */
    footer {
      background: var(--charcoal);
      border-top: 1px solid var(--rule);
      padding: 4rem 4% 2rem;
    }
    .footer-top {
      display: grid; grid-template-columns: 2fr 1fr 1fr 1fr;
      gap: 4rem; padding-bottom: 3rem;
      border-bottom: 1px solid var(--rule); margin-bottom: 2rem;
    }
    .footer-logo img { height: 40px; filter: brightness(0) invert(1); margin-bottom: 1rem; }
    .footer-brand-desc { font-size: 0.78rem; line-height: 1.8; color: var(--muted); max-width: 260px; }
    .footer-col-title {
      font-family: 'DM Mono', monospace;
      font-size: 0.58rem; color: var(--red);
      letter-spacing: 0.2em; text-transform: uppercase; margin-bottom: 1.2rem;
    }
    .footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 0.7rem; }
    .footer-col ul a {
      font-size: 0.78rem; color: var(--muted); text-decoration: none; transition: color 0.2s;
    }
    .footer-col ul a:hover { color: var(--off-white); }
    .footer-bottom {
      display: flex; justify-content: space-between; align-items: center;
      flex-wrap: wrap; gap: 1rem;
    }
    .footer-copy {
      font-family: 'DM Mono', monospace;
      font-size: 0.58rem; color: var(--muted); letter-spacing: 0.08em;
    }
    .footer-certs { display: flex; gap: 0.8rem; }
    .footer-cert-badge {
      font-family: 'DM Mono', monospace;
      font-size: 0.56rem; color: var(--muted);
      letter-spacing: 0.08em; border: 1px solid var(--rule);
      padding: 0.22rem 0.6rem; text-transform: uppercase;
    }

    /* ── MODAL ── */
    .modal-overlay {
      position: fixed; inset: 0; z-index: 200;
      background: rgba(0,0,0,0.88);
      backdrop-filter: blur(8px);
      display: none; align-items: center; justify-content: center; padding: 2rem;
    }
    .modal-overlay.open { display: flex; }
    .modal {
      background: var(--ink-panel);
      border: 1px solid var(--rule);
      border-top: 3px solid var(--red);
      max-width: 540px; width: 100%; padding: 3rem; position: relative;
    }
    .modal-close {
      position: absolute; top: 1rem; right: 1.2rem;
      background: none; border: none; color: var(--muted);
      font-size: 1.5rem; cursor: pointer; line-height: 1;
    }
    .modal-close:hover { color: var(--off-white); }
    .modal-title {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 1.5rem; font-weight: 700; text-transform: uppercase;
      color: var(--white); margin-bottom: 0.3rem; letter-spacing: 0.04em;
    }
    .modal-sub { font-size: 0.78rem; color: var(--muted); margin-bottom: 2rem; }
    .modal-form { display: flex; flex-direction: column; gap: 1rem; }
    .modal-form input, .modal-form textarea {
